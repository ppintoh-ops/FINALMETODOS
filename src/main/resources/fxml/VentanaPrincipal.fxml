<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="15.0" xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.proyectomsw.gui.VentanaPrincipalController">

    <padding>
        <Insets top="20" right="40" bottom="20" left="40"/>
    </padding>

    <Label fx:id="textoBienvenida" text="Gestor de Proyectos" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;" />

    <Button text="+ Crear Nuevo Proyecto" onAction="#crearProyecto" style="-fx-font-size: 14px; -fx-padding: 8 15 8 15; -fx-background-color: #3498db; -fx-text-fill: white; -fx-cursor: hand;" />

    <Label text="Mis Proyectos Guardados:" style="-fx-font-size: 14px; -fx-font-weight: bold;" />
    <ListView fx:id="listaProyectos" prefHeight="300.0" prefWidth="500.0" style="-fx-font-size: 14px;" />

</VBox>